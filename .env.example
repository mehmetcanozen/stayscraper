# .env.example

# --- Application Settings ---
# The port on which the Express.js API server will listen.
PORT=3000

# --- Database (PostgreSQL) Settings ---
# Connection string for your PostgreSQL database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Example for local development: postgresql://user:password@localhost:5432/stayscraper_db
DATABASE_URL="postgresql://user:password@localhost:5432/stayscraper_db"

# --- Redis (BullMQ Backend) Settings ---
# Hostname or IP address of your Redis server.
REDIS_HOST=localhost
# Port of your Redis server.
REDIS_PORT=6379
# Password for your Redis server (leave empty if no password is set).
REDIS_PASSWORD=

# --- Scraping Service API Keys (Optional, if using external services) ---
# API key for your chosen proxy service (e.g., Bright Data, Oxylabs).
# Uncomment and fill if you integrate a proxy service.
# PROXY_API_KEY=your_proxy_service_api_key

# API key for your chosen CAPTCHA solving service (e.g., 2Captcha, Anti-Captcha).
# Uncomment and fill if you integrate a CAPTCHA bypass service.
# CAPTCHA_SOLVER_API_KEY=your_captcha_solver_api_key

# --- Logging Settings (Optional, for specific configurations) ---
# Log level for Winston (e.g., 'debug', 'info', 'warn', 'error').
LOG_LEVEL=debug

# Add any other environment variables your application might need.